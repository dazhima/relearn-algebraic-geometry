<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ document.title }}</title>
  <link rel="stylesheet" href="style.css">
  <script src="lunr.min.js"></script>
  <script>
    window.SEARCH_DOCUMENTS = JSON.parse(new TextDecoder().decode(Uint8Array.from(atob("{{ search_documents|b64_json }}"), (char) => char.charCodeAt(0))));
    window.MathJax = { tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] }, svg: { fontCache: 'global' } };
  </script>
  <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
</head>
<body>
  <aside class="sidebar">
    <a class="brand" href="index.html">Commutative Algebra</a>
    <label class="search-label" for="search">Search</label>
    <input id="search" class="search-input" type="search" placeholder="Search definitions, theorems, examples">
    <div id="search-results" class="search-results" aria-live="polite"></div>
    <nav class="lecture-nav" aria-label="Lectures">
      {% for item in lectures %}
        <a class="lecture-link{% if item.document_id == document.document_id %} current{% endif %}" href="{{ item.href }}">
          <span class="lecture-id">{{ item.document_id }}</span>
          <span>{{ item.title }}</span>
        </a>
      {% endfor %}
      <a class="lecture-link{% if is_homework %} current{% endif %}" href="homework.html">
        <span class="lecture-id">homework</span>
        <span>Problem sets</span>
      </a>
    </nav>
  </aside>

  <main class="content">
    <div class="topline">
      <a href="index.html">Course overview</a>
      {% if not is_homework %}
        <span>{{ document.document_id }}</span>
      {% else %}
        <span>homework</span>
      {% endif %}
    </div>

    <h1>{{ document.title }}</h1>

    {% if not is_homework %}
      <div class="pager">
        {% if document.prev %}<a href="{{ document.prev.document_id }}.html">Previous</a>{% else %}<span></span>{% endif %}
        {% if document.next %}<a href="{{ document.next.document_id }}.html">Next</a>{% endif %}
      </div>
    {% endif %}

    {% for block in document.blocks %}
      <section
        {% if block.anchor_id %}id="{{ block.anchor_id }}"{% endif %}
        class="block block-{{ block.type }}"
      >
        {% if block.type == "section_heading" %}
          <h2>{{ block.heading }}</h2>
        {% elif block.type == "body" %}
          {{ block.html|safe }}
        {% elif block.type == "proof" %}
          <div class="block-title"><em>Proof.</em></div>
          {{ block.html|safe }}
          <span class="qed">□</span>
        {% else %}
          <div class="block-title">{{ block.heading }}</div>
          {{ block.html|safe }}
        {% endif %}
      </section>
    {% endfor %}

    {% if not is_homework %}
      <div class="pager bottom">
        {% if document.prev %}<a href="{{ document.prev.document_id }}.html">Previous</a>{% else %}<span></span>{% endif %}
        {% if document.next %}<a href="{{ document.next.document_id }}.html">Next</a>{% endif %}
      </div>
    {% endif %}
  </main>

  <script>
    (function () {
      const docs = window.SEARCH_DOCUMENTS || [];
      const input = document.getElementById("search");
      const results = document.getElementById("search-results");
      if (!input || !results || docs.length === 0) return;

      if (!window.lunr) {
        input.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();
          results.innerHTML = "";
          if (query.length < 2) return;
          const matches = docs.filter((doc) =>
            `${doc.label || ""} ${doc.type || ""} ${doc.body || ""} ${doc.title || ""}`.toLowerCase().includes(query)
          ).slice(0, 12);
          renderResults(matches);
        });
        return;
      }

      const byId = new Map(docs.map((doc) => [doc.id, doc]));
      const index = lunr(function () {
        this.ref("id");
        this.field("label", { boost: 8 });
        this.field("type", { boost: 2 });
        this.field("body");
        docs.forEach((doc) => this.add(doc));
      });

      input.addEventListener("input", () => {
        const query = input.value.trim();
        results.innerHTML = "";
        if (query.length < 2) return;
        let matches = [];
        try {
          matches = index.search(query + "*").slice(0, 12);
        } catch (_error) {
          matches = index.search(query).slice(0, 12);
        }
        renderResults(matches.map((match) => byId.get(match.ref)).filter(Boolean));
      });

      function renderResults(matches) {
        for (const doc of matches) {
          if (!doc) continue;
          const item = document.createElement("a");
          item.className = "search-result";
          item.href = doc.href;
          item.innerHTML = `<strong>${escapeHtml(doc.label || doc.title)}</strong><span>${escapeHtml(doc.type)} · ${escapeHtml(doc.lecture)}</span>`;
          results.appendChild(item);
        }
      }

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (char) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;"
        }[char]));
      }
    })();
  </script>
</body>
</html>
